---
import { formatPrice } from '../lib/cart.js';
---

<div id="cart-dropdown" class="fixed top-0 right-0 z-50 w-full max-w-sm h-full bg-white shadow-xl transform transition-transform duration-300 translate-x-full" role="dialog" aria-label="Carrito de compras">
  <div class="flex flex-col h-full">
    <div class="flex items-center justify-between px-4 py-3 border-b border-slate-200">
      <h2 class="text-lg font-bold text-vital-dark">Carrito</h2>
      <button id="cart-close" class="text-slate-500 hover:text-vital-dark" aria-label="Cerrar carrito">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto px-4 py-4" id="cart-items">
      <div class="flex flex-col items-center justify-center h-full text-center text-slate-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <p class="text-lg font-medium">Tu carrito está vacío</p>
        <p class="text-sm mt-1">Agrega productos desde el Petshop</p>
      </div>
    </div>

    <div id="cart-footer" class="hidden border-t border-slate-200 px-4 py-4 space-y-4">
      <div class="flex justify-between text-sm">
        <span class="text-slate-600">Subtotal</span>
        <span class="font-semibold text-vital-dark" id="cart-subtotal"></span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-slate-600">Envío</span>
        <span class="font-semibold text-vital-dark">Gratis</span>
      </div>
      <div class="flex justify-between text-lg font-bold text-vital-dark border-t border-slate-200 pt-2">
        <span>Total</span>
        <span id="cart-total"></span>
      </div>
      <div class="flex gap-2">
        <a href="/carrito" class="flex-1 px-4 py-2 text-center text-sm font-semibold text-vital-primary border border-vital-primary rounded-lg hover:bg-vital-secondary transition-colors">Ver carrito</a>
        <a href="/checkout" class="flex-1 px-4 py-2 text-center text-sm font-semibold text-white bg-vital-primary rounded-lg hover:bg-teal-700 transition-colors">Pagar</a>
      </div>
    </div>
  </div>
</div>

<div id="cart-overlay" class="fixed inset-0 z-40 bg-black/50 hidden" aria-hidden="true"></div>

<script>
  function formatPrice(price) {
    return new Intl.NumberFormat('es-CL', {
      style: 'currency',
      currency: 'CLP',
      minimumFractionDigits: 0
    }).format(price);
  }

  function getCart() {
    try {
      const stored = localStorage.getItem('vital-petshop-cart');
      return stored ? JSON.parse(stored) : [];
    } catch {
      return [];
    }
  }

  function getCartTotal() {
    return getCart().reduce((sum, item) => sum + item.price * item.quantity, 0);
  }

  function openCart() {
    document.getElementById('cart-dropdown')?.classList.remove('translate-x-full');
    document.getElementById('cart-overlay')?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeCart() {
    document.getElementById('cart-dropdown')?.classList.add('translate-x-full');
    document.getElementById('cart-overlay')?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    if (e.target.closest('#cart-close') || e.target.closest('#cart-overlay')) {
      closeCart();
    }
  });
  window.addEventListener('cart-open', openCart);

  function renderCart() {
    const items = getCart();
    const container = document.getElementById('cart-items');
    const footer = document.getElementById('cart-footer');

    if (!container) return;

    if (items.length === 0) {
      container.innerHTML = `
        <div class="flex flex-col items-center justify-center h-full text-center text-slate-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <p class="text-lg font-medium">Tu carrito está vacío</p>
          <p class="text-sm mt-1">Agrega productos desde el Petshop</p>
        </div>
      `;
      footer?.classList.add('hidden');
      return;
    }

    container.innerHTML = `
      <ul class="space-y-4" role="list">
        ${items.map(item => `
          <li class="flex gap-3" data-id="${item.id}">
            <img src="${item.imagePath}" alt="${item.name}" class="h-16 w-16 object-cover rounded-lg flex-shrink-0" />
            <div class="flex-1 min-w-0">
              <h3 class="font-medium text-vital-dark truncate">${item.name}</h3>
              <p class="text-sm text-vital-primary font-semibold">${formatPrice(item.price)}</p>
              <div class="flex items-center gap-2 mt-2">
                <button class="cart-qty-btn w-8 h-8 rounded border border-slate-300 flex items-center justify-center hover:bg-slate-100" data-action="decrease" aria-label="Disminuir cantidad">−</button>
                <span class="w-10 text-center text-sm font-medium">${item.quantity}</span>
                <button class="cart-qty-btn w-8 h-8 rounded border border-slate-300 flex items-center justify-center hover:bg-slate-100" data-action="increase" aria-label="Aumentar cantidad">+</button>
                <button class="ml-auto text-slate-400 hover:text-red-500" data-action="remove" aria-label="Eliminar">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </div>
            </div>
            <p class="self-start font-bold text-vital-dark">${formatPrice(item.price * item.quantity)}</p>
          </li>
        `).join('')}
      </ul>
    `;

    footer?.classList.remove('hidden');
    const total = getCartTotal();
    document.getElementById('cart-subtotal').textContent = formatPrice(total);
    document.getElementById('cart-total').textContent = formatPrice(total);
  }

  function saveCart(items) {
    localStorage.setItem('vital-petshop-cart', JSON.stringify(items));
    window.dispatchEvent(new CustomEvent('cart-update', { detail: items }));
  }

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.cart-qty-btn');
    if (!btn) return;

    const itemEl = btn.closest('[data-id]');
    const productId = itemEl?.dataset.id;
    if (!productId) return;

    const items = getCart();
    const item = items.find(i => i.id === productId);
    if (!item) return;

    if (btn.dataset.action === 'increase') {
      item.quantity += 1;
    } else if (btn.dataset.action === 'decrease') {
      item.quantity -= 1;
      if (item.quantity <= 0) {
        saveCart(items.filter(i => i.id !== productId));
        renderCart();
        return;
      }
    }
    saveCart(items);
  });

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-action="remove"]');
    if (!btn) return;

    const itemEl = btn.closest('[data-id]');
    const productId = itemEl?.dataset.id;
    if (productId) {
      saveCart(getCart().filter(i => i.id !== productId));
    }
  });

  window.addEventListener('cart-update', renderCart);
  document.addEventListener('astro:page-load', renderCart);
  renderCart();
</script>

<style>
  @media (max-width: 640px) {
    #cart-dropdown {
      max-width: 100%;
    }
  }
</style>