---
interface Props {
  name: string;
  specialty: string;
  imagePath: string;
  bio: string;
}

const { name, specialty, imagePath, bio } = Astro.props;
---

<article class="flex flex-col overflow-hidden rounded-xl bg-white shadow-md">
  <img src={imagePath} alt={name} class="h-64 w-full object-cover" loading="lazy" />
  <div class="p-5">
    <h3 class="text-xl font-heading font-bold text-vital-dark">{name}</h3>
    <p class="mb-3 text-sm font-semibold text-vital-primary">{specialty}</p>
    <p class="line-clamp-3 text-sm text-slate-600">{bio}</p>
  </div>
</article>
