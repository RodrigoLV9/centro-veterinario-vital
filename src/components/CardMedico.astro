---
interface Props {
  image: string;
  name: string;
  specialty: string;
  description?: string;
}

const { image, name, specialty, description } = Astro.props;
---

<article class="flex flex-col items-center rounded-xl bg-white p-6 text-center shadow-lg transition-transform hover:-translate-y-1">
  <img
    src={image}
    alt={name}
    class="mb-4 h-40 w-40 rounded-full object-cover shadow-md"
    width="160"
    height="160"
    loading="lazy"
  />
  <h3 class="text-xl font-semibold text-vital-dark">{name}</h3>
  <p class="mb-2 text-sm font-medium text-vital-primary">{specialty}</p>
  {description && <p class="text-vital-dark/70">{description}</p>}
</article>
