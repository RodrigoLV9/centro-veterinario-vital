---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'outline';
}

const { href, type, variant = 'primary' } = Astro.props;

const styles = {
  primary:
    'bg-vital-primary text-white hover:bg-vital-primary/90 shadow-md',
  outline:
    'border-2 border-vital-primary text-vital-primary hover:bg-vital-primary hover:text-white',
};

const classes = `inline-block rounded-lg px-6 py-3 font-semibold transition-colors ${styles[variant]}`;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type ?? 'button'} class={classes}>
      <slot />
    </button>
  )
}
