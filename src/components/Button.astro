---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  text: string;
  variant?: 'primary' | 'outline';
  className?: string;
}

const { href, type, text, variant = 'primary', className = '' } = Astro.props;

const base = 'px-6 py-2 rounded-lg font-semibold text-center transition-colors duration-300';

const variants = {
  primary: 'bg-vital-primary text-white hover:bg-teal-700',
  outline:
    'bg-transparent border-2 border-vital-primary text-vital-primary hover:bg-vital-secondary',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes}>
      {text}
    </a>
  ) : (
    <button type={type ?? 'button'} class={classes}>
      {text}
    </button>
  )
}
