---
const currentPath = Astro.url.pathname;
const isActive = (href) => {
  if (href === '/servicios') return currentPath.startsWith('/servicios');
  return currentPath === href;
};
const linkBase = 'transition-colors duration-200';
const linkActive = 'font-semibold text-vital-primary';
const linkInactive = 'text-vital-dark hover:text-vital-primary';
---

<header class="fixed top-0 z-50 w-full bg-white shadow-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center gap-2 font-heading text-xl font-bold text-vital-primary">
      <img src="/favicon.png" alt="" class="h-10 w-10" />
      Centro Veterinario Vital
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      <a href="/" class={`${linkBase} ${isActive('/') ? linkActive : linkInactive}`}>Inicio</a>
      <div class="group relative">
        <a href="/servicios" class={`${linkBase} inline-flex items-center gap-1 ${isActive('/servicios') ? linkActive : linkInactive}`}>
          Servicios
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <div class="invisible absolute left-0 top-full z-50 w-56 rounded-xl bg-white py-2 shadow-lg opacity-0 transition-all group-hover:visible group-hover:opacity-100">
          {
            [
              { href: '/servicios/clinica-general', label: 'Clínica General' },
              { href: '/servicios/diagnostico-imagenes', label: 'Diagnóstico por Imágenes' },
              { href: '/servicios/vacunacion', label: 'Vacunación' },
              { href: '/servicios/cirugia-general', label: 'Cirugía General' },
              { href: '/servicios/peluqueria', label: 'Peluquería' },
              { href: '/servicios/analisis-clinicos', label: 'Análisis Clínicos' },
              { href: '/servicios/odontologia', label: 'Odontología' },
            ].map((s) => (
              <a
                href={s.href}
                class={`block px-4 py-2 text-sm ${currentPath === s.href ? 'font-semibold text-vital-primary bg-vital-secondary/30' : 'text-vital-dark hover:bg-vital-secondary/30 hover:text-vital-primary'}`}
              >{s.label}</a>
            ))
          }
          <div class="mx-3 my-1 border-t border-slate-100"></div>
          <a href="/servicios/urgencias" class={`block px-4 py-2 text-sm font-semibold ${currentPath === '/servicios/urgencias' ? 'text-red-700 bg-red-50' : 'text-red-600 hover:bg-red-50'}`}>Urgencias 24h</a>
        </div>
      </div>
      <a href="/equipo" class={`${linkBase} ${isActive('/equipo') ? linkActive : linkInactive}`}>Equipo</a>
      <a href="/petshop" class={`${linkBase} ${isActive('/petshop') ? linkActive : linkInactive}`}>Petshop</a>
      <a href="/contacto" class={`${linkBase} ${isActive('/contacto') ? linkActive : linkInactive}`}>Contacto</a>
      <a href="/turnos" class="rounded-lg bg-vital-primary px-4 py-2 font-semibold text-white transition-all duration-300 hover:bg-teal-700 hover:shadow-lg hover:ring-2 hover:ring-inset hover:ring-white/20">Agendar Turno</a>
    </nav>

    <button id="menu-toggle" class="md:hidden" aria-label="Abrir menú">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-vital-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="max-h-0 overflow-hidden opacity-0 transition-all duration-300 ease-out border-t border-slate-200 bg-white px-4 md:hidden">
    <div class="flex flex-col gap-1 pt-4 pb-4">
      <a href="/" class={`rounded-lg px-4 py-2.5 text-sm font-medium ${isActive('/') ? 'bg-vital-primary/10 text-vital-primary' : 'text-vital-dark hover:bg-slate-50'}`}>Inicio</a>
      <div>
        <button id="mobile-services-toggle" class={`flex w-full items-center justify-between rounded-lg px-4 py-2.5 text-sm font-medium ${currentPath.startsWith('/servicios') ? 'bg-vital-primary/10 text-vital-primary' : 'text-vital-dark hover:bg-slate-50'}`}>
          Servicios
          <svg id="mobile-services-arrow" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="mobile-services-submenu" class="ml-4 mt-1 hidden flex-col gap-1 border-l-2 border-vital-primary/20 pl-3">
          {
            [
              { href: '/servicios/clinica-general', label: 'Clínica General' },
              { href: '/servicios/diagnostico-imagenes', label: 'Diagnóstico por Imágenes' },
              { href: '/servicios/vacunacion', label: 'Vacunación' },
              { href: '/servicios/cirugia-general', label: 'Cirugía General' },
              { href: '/servicios/peluqueria', label: 'Peluquería' },
              { href: '/servicios/analisis-clinicos', label: 'Análisis Clínicos' },
              { href: '/servicios/odontologia', label: 'Odontología' },
            ].map((s) => (
              <a
                href={s.href}
                class={`block rounded-lg px-3 py-2 text-sm ${currentPath === s.href ? 'font-semibold text-vital-primary bg-vital-primary/5' : 'text-slate-600 hover:bg-slate-50 hover:text-vital-primary'}`}
              >{s.label}</a>
            ))
          }
          <a href="/servicios/urgencias" class={`block rounded-lg px-3 py-2 text-sm font-semibold ${currentPath === '/servicios/urgencias' ? 'text-red-700 bg-red-50' : 'text-red-600 hover:bg-red-50'}`}>Urgencias 24h</a>
        </div>
      </div>
      <a href="/equipo" class={`rounded-lg px-4 py-2.5 text-sm font-medium ${isActive('/equipo') ? 'bg-vital-primary/10 text-vital-primary' : 'text-vital-dark hover:bg-slate-50'}`}>Equipo</a>
      <a href="/petshop" class={`rounded-lg px-4 py-2.5 text-sm font-medium ${isActive('/petshop') ? 'bg-vital-primary/10 text-vital-primary' : 'text-vital-dark hover:bg-slate-50'}`}>Petshop</a>
      <a href="/contacto" class={`rounded-lg px-4 py-2.5 text-sm font-medium ${isActive('/contacto') ? 'bg-vital-primary/10 text-vital-primary' : 'text-vital-dark hover:bg-slate-50'}`}>Contacto</a>
      <a href="/turnos" class="mt-2 rounded-lg bg-vital-primary px-4 py-2.5 text-center text-sm font-semibold text-white transition-all hover:bg-teal-700">Agendar Turno</a>
    </div>
  </nav>
</header>

<script>
  function openMenu(open) {
    const menu = document.getElementById('mobile-menu');
    if (!menu) return;
    const isOpen = open ?? menu.classList.contains('max-h-0');
    menu.classList.toggle('max-h-0', !isOpen);
    menu.classList.toggle('max-h-[80vh]', isOpen);
    menu.classList.toggle('opacity-0', !isOpen);
    menu.classList.toggle('opacity-100', isOpen);
  }

  document.addEventListener('click', (e) => {
    if (e.target.closest('#menu-toggle')) {
      openMenu();
      return;
    }

    const servicesBtn = e.target.closest('#mobile-services-toggle');
    if (servicesBtn) {
      const submenu = document.getElementById('mobile-services-submenu');
      const arrow = document.getElementById('mobile-services-arrow');
      submenu?.classList.toggle('hidden');
      arrow?.classList.toggle('rotate-180');
    }
  });

  document.addEventListener('astro:page-load', () => openMenu(false));
</script>
