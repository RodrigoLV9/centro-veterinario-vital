---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
---

<Layout title="Carrito de Compras">
  <section class="bg-vital-primary px-4 py-20 text-center text-white md:px-8 lg:px-16">
    <h1 class="text-4xl font-bold md:text-5xl">Carrito de Compras</h1>
  </section>

  <section class="px-4 py-16 md:px-8 lg:px-16">
    <div class="mx-auto max-w-5xl">
      <div id="cart-page-empty" class="hidden text-center py-20">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 mx-auto mb-6 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <h2 class="text-2xl font-bold text-vital-dark mb-2">Tu carrito está vacío</h2>
        <p class="text-slate-600 mb-8">Agrega productos desde nuestro Petshop para comenzar tu compra.</p>
        <Button href="/petshop" text="Ir al Petshop" />
      </div>

      <div id="cart-page-content" class="hidden">
        <div class="mb-8">
          <button id="cart-page-clear" class="text-sm text-red-500 hover:text-red-700 font-medium">Vaciar carrito</button>
        </div>

        <div class="space-y-6" id="cart-page-items"></div>

        <div class="mt-10 border-t border-slate-200 pt-8">
          <div class="flex flex-col md:flex-row gap-8 md:justify-between">
            <div class="w-full md:w-1/2 space-y-4">
              <h3 class="text-xl font-bold text-vital-dark">Resumen de Compra</h3>
              <div class="flex justify-between text-sm">
                <span class="text-slate-600">Subtotal</span>
                <span class="font-semibold text-vital-dark" id="cart-page-subtotal">$0</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-slate-600">Envío</span>
                <span class="font-semibold text-vital-dark">Gratis</span>
              </div>
              <div class="flex justify-between text-lg font-bold text-vital-dark border-t border-slate-200 pt-4">
                <span>Total</span>
                <span id="cart-page-total">$0</span>
              </div>
            </div>
            <div class="w-full md:w-auto">
              <a href="/checkout" class="block w-full md:w-auto px-8 py-3 text-center text-base font-semibold text-white bg-vital-primary rounded-lg hover:bg-teal-700 transition-colors">
                Ir a Pagar
              </a>
              <a href="/petshop" class="block mt-4 text-center text-sm text-vital-primary hover:underline">Seguir comprando</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  function formatPrice(price) {
    return new Intl.NumberFormat('es-CL', {
      style: 'currency',
      currency: 'CLP',
      minimumFractionDigits: 0
    }).format(price);
  }

  function renderCartPage() {
    const items = window.cart?.items?.() ?? [];
    const emptyEl = document.getElementById('cart-page-empty');
    const contentEl = document.getElementById('cart-page-content');
    const itemsContainer = document.getElementById('cart-page-items');

    if (items.length === 0) {
      emptyEl?.classList.remove('hidden');
      contentEl?.classList.add('hidden');
      return;
    }

    emptyEl?.classList.add('hidden');
    contentEl?.classList.remove('hidden');

    if (itemsContainer) {
      itemsContainer.innerHTML = items.map(item => `
        <div class="flex gap-4 p-4 bg-white rounded-xl shadow-sm border border-slate-100" data-id="${item.id}">
          <img src="${item.imagePath}" alt="${item.name}" class="h-24 w-24 object-cover rounded-lg flex-shrink-0" />
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-vital-dark text-lg">${item.name}</h3>
            <p class="text-vital-primary font-bold">${formatPrice(item.price)}</p>
            <div class="flex items-center gap-3 mt-3">
              <button class="cart-page-qty-btn w-8 h-8 rounded border border-slate-300 flex items-center justify-center hover:bg-slate-100 font-medium" data-action="decrease">−</button>
              <span class="w-10 text-center font-medium">${item.quantity}</span>
              <button class="cart-page-qty-btn w-8 h-8 rounded border border-slate-300 flex items-center justify-center hover:bg-slate-100 font-medium" data-action="increase">+</button>
              <button class="ml-4 text-slate-400 hover:text-red-500" data-action="remove">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          </div>
          <p class="self-start font-bold text-vital-dark text-lg">${formatPrice(item.price * item.quantity)}</p>
        </div>
      `).join('');
    }

    const total = window.cart?.total?.() ?? 0;
    document.getElementById('cart-page-subtotal').textContent = formatPrice(total);
    document.getElementById('cart-page-total').textContent = formatPrice(total);
  }

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.cart-page-qty-btn');
    if (!btn) return;

    const itemEl = btn.closest('[data-id]');
    const productId = itemEl?.dataset.id;
    if (!productId || !window.cart) return;

    const items = window.cart.items();
    const item = items.find(i => i.id === productId);
    if (!item) return;

    if (btn.dataset.action === 'increase') {
      window.cart.updateQuantity(productId, item.quantity + 1);
    } else if (btn.dataset.action === 'decrease') {
      window.cart.updateQuantity(productId, item.quantity - 1);
    }
    renderCartPage();
  });

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-action="remove"]');
    if (!btn) return;

    const itemEl = btn.closest('[data-id]');
    const productId = itemEl?.dataset.id;
    if (productId && window.cart) {
      window.cart.remove(productId);
      renderCartPage();
    }
  });

  document.getElementById('cart-page-clear')?.addEventListener('click', () => {
    if (window.cart) {
      window.cart.clear();
      renderCartPage();
    }
  });

  window.addEventListener('cart-update', renderCartPage);
  renderCartPage();
</script>