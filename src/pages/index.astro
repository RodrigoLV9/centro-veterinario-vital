---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import CardServicio from "../components/CardServicio.astro";
---

<Layout title="Inicio">
  <section
    class="grid items-center gap-8 px-4 py-16 md:grid-cols-2 md:px-8 lg:px-16"
  >
    <div class="flex flex-col gap-6">
      <h1 class="text-4xl font-bold leading-tight text-vital-dark md:text-5xl">
        Atención veterinaria integral y de confianza
      </h1>
      <p class="text-lg leading-relaxed text-vital-dark/70">
        En Centro Veterinario Vital brindamos cuidado profesional y
        personalizado para tu mascota. Contamos con equipamiento moderno y un
        equipo de especialistas dedicados a su bienestar.
      </p>
      <div class="flex flex-wrap gap-4">
        <Button href="/turnos" text="Agendar Turno" />
        <Button href="/servicios" variant="outline" text="Ver Servicios" />
      </div>
    </div>
    <div>
      <img
        src="/images/hero-inicio.png"
        alt="Veterinario atendiendo a un perro"
        class="rounded-2xl shadow-xl"
        width="600"
        height="400"
        loading="eager"
      />
    </div>
  </section>

  <section class="bg-vital-accent px-4 py-8 text-center text-white md:px-8">
    <p class="text-lg font-semibold">🚨 Guardia Veterinaria 24hs</p>
    <p class="mt-2 text-3xl font-bold md:text-4xl">(123) 456-7890</p>
  </section>

  <section class="bg-vital-secondary/30 px-4 py-16 md:px-8 lg:px-16">
    <h2 class="mb-12 text-center text-3xl font-bold text-vital-dark">
      Nuestros Servicios
    </h2>
    <div class="grid gap-8 md:grid-cols-3">
      <CardServicio
        iconName="ph:stethoscope"
        title="Clínica General"
        description="Consultas de rutina, chequeos generales y medicina preventiva para mantener a tu mascota saludable."
      />
      <CardServicio
        iconName="ph:syringe"
        title="Vacunación"
        description="Plan de vacunación completo y desparasitación, siguiendo el calendario vigente."
      />
      <CardServicio
        iconName="ph:bandaids"
        title="Cirugías"
        description="Procedimientos quirúrgicos programados y de urgencia con equipamiento de última generación."
      />
    </div>
  </section>
</Layout>
