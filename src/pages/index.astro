---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import CardServicio from "../components/CardServicio.astro";

const services = [
  {
    slug: "clinica-general",
    iconName: "ph:stethoscope",
    title: "Clínica General",
    description:
      "Consultas de rutina, chequeos generales y medicina preventiva.",
  },
  {
    slug: "vacunacion",
    iconName: "ph:syringe",
    title: "Vacunación",
    description: "Plan de vacunación completo siguiendo el calendario vigente.",
  },
  {
    slug: "cirugia-general",
    iconName: "ph:bandaids",
    title: "Cirugías",
    description:
      "Procedimientos programados y de urgencia con equipamiento moderno.",
  },
  {
    slug: "diagnostico-imagenes",
    iconName: "ph:scan",
    title: "Diagnóstico por Imágenes",
    description: "Radiología digital y ecografía para diagnósticos precisos.",
  },
  {
    slug: "peluqueria",
    iconName: "ph:scissors",
    title: "Peluquería",
    description: "Baño, corte higiénico y estético para todas las razas.",
  },
  {
    slug: "analisis-clinicos",
    iconName: "ph:flask",
    title: "Análisis Clínicos",
    description: "Laboratorio interno con resultados rápidos.",
  },
];
---

<Layout title="Centro Veterinario Vital - Atención integral para tu mascota">
  <section
    class="relative overflow-hidden bg-gradient-to-br from-vital-primary to-teal-800 md:bg-none"
  >
    <div
      class="mx-auto grid items-center gap-8 px-4 py-20 md:grid-cols-2 md:px-8 lg:px-16 lg:py-28"
    >
      <div class="relative z-10 flex flex-col gap-6">
        <span
          class="inline-flex w-fit rounded-full bg-white/15 px-4 py-1.5 text-sm font-medium text-white/90 backdrop-blur-sm"
        >
          Expertos en salud animal
        </span>
        <h1
          class="text-4xl font-bold leading-tight text-white md:text-5xl lg:text-6xl"
        >
          Atención veterinaria <span class="text-amber-300">integral</span> y de confianza
        </h1>
        <p class="max-w-xl text-lg leading-relaxed text-white/80">
          Brindamos cuidado profesional y personalizado para tu mascota.
          Contamos con equipamiento moderno y un equipo de especialistas
          dedicados a su bienestar.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button
            href="/turnos"
            variant="outline"
            text="Agendar Turno"
            className="border-white text-white hover:bg-white hover:text-vital-primary"
          />
          <a
            href="/servicios"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white px-6 py-2 font-semibold text-white transition-colors hover:bg-white hover:text-vital-primary"
          >
            Ver Servicios
          </a>
        </div>
      </div>
    </div>
    <div class="absolute inset-0 hidden md:block">
      <div
        class="absolute inset-0 bg-gradient-to-r from-vital-primary via-vital-primary/95 to-transparent"
      >
      </div>
      <img
        src="/images/hero-inicio.webp"
        alt=""
        class="h-full w-full object-cover"
        aria-hidden="true"
        fetchpriority="high"
      />
    </div>
  </section>

  <section class="bg-amber-500 px-4 py-8 text-center text-white md:px-8">
    <p class="text-lg font-semibold">
      🚨 Guardia Veterinaria 24hs — Los 365 días del año
    </p>
    <p class="mt-2 text-3xl font-bold md:text-4xl">(123) 456-7890</p>
  </section>

  <section class="bg-vital-secondary/30 px-4 py-20 md:px-8 lg:px-16">
    <div class="mx-auto max-w-6xl">
      <div class="mb-4 text-center">
        <h2 class="text-3xl font-bold text-vital-dark">Nuestros Servicios</h2>
        <p class="mt-2 text-lg text-vital-dark/60">
          Todo lo que tu mascota necesita en un solo lugar
        </p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((s) => (
            <a
              href={`/servicios/${s.slug}`}
              class="group block transition hover:-translate-y-1"
            >
              <CardServicio
                iconName={s.iconName}
                title={s.title}
                description={s.description}
              />
            </a>
          ))
        }
      </div>
      <div class="mt-10 text-center">
        <Button
          href="/servicios"
          variant="outline"
          text="Ver todos los servicios"
        />
      </div>
    </div>
  </section>

  <section class="px-4 py-20 md:px-8 lg:px-16">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold text-vital-dark">
          ¿Por qué elegir Vital?
        </h2>
        <p class="mt-2 text-lg text-vital-dark/60">
          Nos diferenciamos por nuestro compromiso y calidez
        </p>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-xl bg-white p-8 text-center shadow-md">
          <div
            class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-vital-primary/10"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7 text-vital-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-2 text-lg font-bold text-vital-dark">
            Enfoque Fear-Free
          </h3>
          <p class="text-sm leading-relaxed text-slate-600">
            Atención libre de estrés con protocolos que priorizan el bienestar
            emocional de tu mascota.
          </p>
        </div>
        <div class="rounded-xl bg-white p-8 text-center shadow-md">
          <div
            class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-vital-primary/10"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7 text-vital-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-2 text-lg font-bold text-vital-dark">
            Equipamiento Moderno
          </h3>
          <p class="text-sm leading-relaxed text-slate-600">
            Tecnología de última generación para diagnósticos precisos y
            tratamientos efectivos.
          </p>
        </div>
        <div class="rounded-xl bg-white p-8 text-center shadow-md">
          <div
            class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-vital-primary/10"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7 text-vital-primary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-2 text-lg font-bold text-vital-dark">
            Equipo Especializado
          </h3>
          <p class="text-sm leading-relaxed text-slate-600">
            Profesionales con formación continua y experiencia en múltiples
            disciplinas veterinarias.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-vital-secondary/30 px-4 py-20 md:px-8 lg:px-16">
    <div class="mx-auto max-w-6xl">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div>
          <h2 class="mb-4 text-3xl font-bold text-vital-dark">
            Conocé nuestro equipo
          </h2>
          <p class="mb-6 leading-relaxed text-slate-600">
            Detrás de cada atención hay un equipo de profesionales apasionados
            por la salud animal. Especialistas en medicina general, cirugía,
            diagnóstico por imágenes, odontología y más, trabajando juntos para
            brindar la mejor experiencia a tu mascota.
          </p>
          <div class="flex flex-wrap gap-4">
            <Button href="/equipo" text="Conocer al equipo" />
            <Button href="/contacto" variant="outline" text="Contactarnos" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <img
            src="/images/equipo-dra-general.webp"
            alt="Dra. Laura Méndez"
            class="rounded-xl shadow-md"
            loading="lazy"
          />
          <img
            src="/images/equipo-dr-felinos.webp"
            alt="Dr. Carlos Ruiz"
            class="mt-6 rounded-xl shadow-md"
            loading="lazy"
          />
          <img
            src="/images/equipo-dra-cirugia.webp"
            alt="Dra. Sofía Torres"
            class="rounded-xl shadow-md"
            loading="lazy"
          />
          <img
            src="/images/equipo-dr-imagenes.webp"
            alt="Dr. Martín López"
            class="mt-6 rounded-xl shadow-md"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-20 md:px-8 lg:px-16">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-12 text-center text-3xl font-bold text-vital-dark">
        Lo que dicen nuestros clientes
      </h2>
      <div class="grid gap-8 md:grid-cols-2">
        <div class="rounded-xl bg-vital-secondary/30 p-8">
          <div class="mb-4 flex items-center gap-4">
            <img
              src="/images/testimonio-perro.webp"
              alt="Cliente"
              class="h-14 w-14 rounded-full object-cover"
              loading="lazy"
            />
            <div>
              <p class="font-bold text-vital-dark">María González</p>
              <p class="text-sm text-vital-primary">Dueña de Loki</p>
            </div>
          </div>
          <div class="mb-3 flex text-amber-400">
            {
              Array.from({ length: 5 }).map(() => (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))
            }
          </div>
          <p class="text-sm leading-relaxed text-slate-600">
            "Desde la primera visita notamos la diferencia. Loki solía
            estresarse en el veterinario, pero aquí lo trataron con tanta
            paciencia y cariño que ahora viene feliz."
          </p>
        </div>
        <div class="rounded-xl bg-vital-secondary/30 p-8">
          <div class="mb-4 flex items-center gap-4">
            <img
              src="/images/testimonio-gato.webp"
              alt="Cliente"
              class="h-14 w-14 rounded-full object-cover"
              loading="lazy"
            />
            <div>
              <p class="font-bold text-vital-dark">Pedro Ramírez</p>
              <p class="text-sm text-vital-primary">Dueño de Mía</p>
            </div>
          </div>
          <div class="mb-3 flex text-amber-400">
            {
              Array.from({ length: 5 }).map(() => (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))
            }
          </div>
          <p class="text-sm leading-relaxed text-slate-600">
            "Mía es una gata muy sensible y siempre había sido un desafío
            llevarla al veterinario. El Dr. Ruiz fue increíblemente paciente,
            usó feromonas y la atendió en una habitación tranquila."
          </p>
        </div>
      </div>
    </div>
  </section>

  <section
    class="bg-gradient-to-br from-vital-primary to-teal-800 px-4 py-20 text-white md:px-8 lg:px-16"
  >
    <div class="mx-auto max-w-6xl">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div>
          <h2 class="mb-4 text-3xl font-bold md:text-4xl">
            Visitá nuestro Petshop
          </h2>
          <p class="mb-6 max-w-md text-lg text-white/80">
            Encontrá alimentos balanceados, accesorios, juguetes y productos de
            higiene para tu mascota. Todo lo que necesitás en un solo lugar.
          </p>
          <Button
            href="/petshop"
            variant="outline"
            text="Ir al Petshop"
            className="border-white text-white hover:bg-white hover:text-vital-primary"
          />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <img
            src="/images/royal-canin-maxi-adult-15kg.jpg"
            alt="Royal Canin"
            class="rounded-xl shadow-md"
            loading="lazy"
          />
          <img
            src="/images/rascador-para-gatos-3-niveles.webp"
            alt="Rascador para gatos"
            class="mt-6 rounded-xl shadow-md"
            loading="lazy"
          />
          <img
            src="/images/cepillo-deslanador-furminator.webp"
            alt="Cepillo Furminator"
            class="rounded-xl shadow-md"
            loading="lazy"
          />
          <img
            src="/images/bebedero-automatico-2L.webp"
            alt="Bebedero automático"
            class="mt-6 rounded-xl shadow-md"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-20 text-center md:px-8">
    <h2 class="mb-4 text-3xl font-bold text-vital-dark">
      ¿Listo para agendar una consulta?
    </h2>
    <p class="mb-8 mx-auto max-w-xl text-lg text-vital-dark/70">
      Reservá un turno con nuestros especialistas y asegurate de que tu mascota
      reciba la mejor atención.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <Button href="/turnos" text="Agendar Turno" />
      <Button href="/contacto" variant="outline" text="Consultar" />
    </div>
  </section>
</Layout>
